{
  "info": {
    "_postman_id": "389705dc-4d7d-4898-85dc-dd7eb584c799",
    "name": "banyan_application",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "51787170",
    "_collection_link": "https://go.postman.co/collection/51787170-389705dc-4d7d-4898-85dc-dd7eb584c799?source=collection_link"
  },
  "item": [
    {
      "name": "login_api",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Generate dynamic device ID\r",
              "const uuid = () => {\r",
              "    return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'\r",
              "        .replace(/[xy]/g, function(c) {\r",
              "            const r = Math.random() * 16 | 0;\r",
              "            const v = c === 'x' ? r : (r & 0x3 | 0x8);\r",
              "            return v.toString(16);\r",
              "        });\r",
              "};\r",
              "\r",
              "// Set dynamic values\r",
              "pm.environment.set(\"deviceId\", uuid());\r",
              "\r",
              "pm.environment.set(\"latitude\", \"13.061361543287191\");\r",
              "pm.environment.set(\"longitude\", \"80.26007440007787\");\r",
              "\r",
              "// Logging\r",
              "console.log(\"Generated Device ID:\", pm.environment.get(\"deviceId\"));"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Parse response\r",
              "let responseJson = pm.response.json();\r",
              "\r",
              "\r",
              "// =============================\r",
              "// STATUS CODE VALIDATION\r",
              "// =============================\r",
              "pm.test(\"Status code should be 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "\r",
              "// =============================\r",
              "// RESPONSE TIME VALIDATION\r",
              "// =============================\r",
              "pm.test(\"Response time should be below 3000 ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(3000);\r",
              "});\r",
              "\r",
              "\r",
              "// =============================\r",
              "// CONTENT TYPE VALIDATION\r",
              "// =============================\r",
              "pm.test(\"Content-Type should be application/json\", function () {\r",
              "    pm.expect(\r",
              "        pm.response.headers.get(\"Content-Type\")\r",
              "    ).to.include(\"application/json\");\r",
              "});\r",
              "\r",
              "\r",
              "// =============================\r",
              "// RESPONSE BODY VALIDATION\r",
              "// =============================\r",
              "pm.test(\"Response body should not be empty\", function () {\r",
              "    pm.expect(responseJson).to.not.be.null;\r",
              "});\r",
              "\r",
              "\r",
              "// =============================\r",
              "// KEY VALIDATION\r",
              "// =============================\r",
              "pm.test(\"Validate important response keys\", function () {\r",
              "\r",
              "    pm.expect(responseJson).to.have.property(\"status\");\r",
              "    pm.expect(responseJson).to.have.property(\"message\");\r",
              "    pm.expect(responseJson).to.have.property(\"data\");\r",
              "\r",
              "    pm.expect(responseJson.data).to.have.property(\"accessToken\");\r",
              "    pm.expect(responseJson.data).to.have.property(\"refreshToken\");\r",
              "    pm.expect(responseJson.data).to.have.property(\"id\");\r",
              "\r",
              "});\r",
              "\r",
              "\r",
              "// =============================\r",
              "// BUSINESS VALIDATION\r",
              "// =============================\r",
              "pm.test(\"Login success message validation\", function () {\r",
              "\r",
              "    pm.expect(responseJson.message)\r",
              "        .to.eql(\"You’ve successfully signed in\");\r",
              "\r",
              "                \r",
              "\r",
              "});\r",
              "\r",
              "\r",
              "// =============================\r",
              "// TOKEN VALIDATION\r",
              "// =============================\r",
              "pm.test(\"Access token should not be empty\", function () {\r",
              "\r",
              "    pm.expect(responseJson.data.accessToken)\r",
              "        .to.not.be.empty;\r",
              "\r",
              "});\r",
              "\r",
              "\r",
              "// =============================\r",
              "// SAVE TOKENS\r",
              "// =============================\r",
              "pm.environment.set(\r",
              "    \"accessToken\",\r",
              "    responseJson.data.accessToken\r",
              ");\r",
              "\r",
              "pm.environment.set(\r",
              "    \"refreshToken\",\r",
              "    responseJson.data.refreshToken\r",
              ");\r",
              "\r",
              "pm.environment.set(\r",
              "    \"userId\",\r",
              "    responseJson.data.id\r",
              ");\r",
              "\r",
              "\r",
              "// =============================\r",
              "// CONSOLE LOGGING\r",
              "// =============================\r",
              "console.log(\"Access Token:\", responseJson.data.accessToken);\r",
              "\r",
              "console.log(\"Refresh Token:\", responseJson.data.refreshToken);\r",
              "\r",
              "console.log(\"User ID:\", responseJson.data.id);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"mobile\": \"9840127991\",\r\n    \"password\": \"12345678\",\r\n    \"accountType\": \"STAFF\",\r\n    \"platformType\": \"WEB\",\r\n    \"deviceId\": \"{{deviceId}}\",\r\n    \"token\": \"\",\r\n    \"latitude\": \"{{latitude}}\",\r\n    \"longitude\": \"{{longitude}}\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "https://sbioa-gateway-dev.coherent.in/sbioa-auth/v2/auth/password-login",
          "protocol": "https",
          "host": [
            "sbioa-gateway-dev",
            "coherent",
            "in"
          ],
          "path": [
            "sbioa-auth",
            "v2",
            "auth",
            "password-login"
          ]
        }
      },
      "response": []
    }
  ]
}